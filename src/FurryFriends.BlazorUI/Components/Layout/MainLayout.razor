@inherits LayoutComponentBase
@using FurryFriends.BlazorUI.Client
@using FurryFriends.BlazorUI.Client.Components.Common
@using FurryFriends.BlazorUI.Client.Pages.PetWalkers
@inject NavigationManager NavigationManager

<div class="app-layout">
    <!-- Sidebar -->
    <aside class="sidebar @(_sidebarCollapsed ? "collapsed" : "")">
        <button class="sidebar-toggle" type="button" @onclick="ToggleSidebar" aria-label="Toggle navigation">
            <i class="fa-solid fa-bars" aria-hidden="true"></i>
        </button>
        <div class="sidebar-header">
            <a href="" @onclick="NavigateToHome" class="no-underline">
                <i class="fa-solid fa-paw"></i> Furry Friends
            </a>
        </div>
        <NavMenu />
        <div class="sidebar-footer">
            Version 1.0.0
        </div>
    </aside>

    <!-- Main Content -->
    <div class="main-content">
        <!-- Top Header -->
        <header class="top-header">
            <div class="header-search">
                <i class="fa-solid fa-magnifying-glass search-icon"></i>
                <input type="text" placeholder="Search dashboard..." disabled />
                <span class="search-badge">Ctrl K</span>
            </div>
            <div class="header-actions">
                <!-- Notification Tray -->
                <div class="notification-badge">
                    <i class="fa-solid fa-bell"></i>
                    <span class="badge-count pulse">3</span>
                </div>

                <!-- Profile Dropdown -->
                <div class="user-menu" @onclick="ToggleProfileDropdown" @onclick:preventDefault="true">
                    <div class="user-avatar">RB</div>
                    <span class="user-name">Robert Bravery</span>
                    <i class="fa-solid fa-angle-down dropdown-arrow"></i>
                </div>

                <!-- Profile Dropdown Menu -->
                <div class="profile-dropdown @(_profileDropdownOpen ? "open" : "")">
                    <div class="profile-dropdown-item">
                        <i class="fa-solid fa-user"></i>
                        <span>My Profile</span>
                    </div>
                    <div class="profile-dropdown-item">
                        <i class="fa-solid fa-gear"></i>
                        <span>Settings</span>
                    </div>
                    <div class="profile-dropdown-divider"></div>
                    <div class="profile-dropdown-item" title="Log Out">
                        <i class="fa-solid fa-right-from-bracket"></i>
                        <span>Sign Out</span>
                    </div>
                </div>

                <!-- Logout Action -->
                <div class="icon-button logout-btn" title="Log Out">
                    <i class="fa-solid fa-right-from-bracket"></i>
                </div>
            </div>
        </header>

        <!-- Page Content -->
        <main class="page-content">
            @Body
        </main>

        <!-- Popup Managers -->
        <ClientEditPopupManager />
        <ClientViewPopupManager />
        <CreateClientPopupManager />
        <PetWalkerViewPopupManager />
        <EditPetWalkerPopupManager />
        <ManagePetWalkerPhotosPopup />
    </div>
</div>

@code {
    private bool _profileDropdownOpen = false;
    private bool _sidebarCollapsed = false;

    private void ToggleSidebar()
    {
        _sidebarCollapsed = !_sidebarCollapsed;
    }

    private void NavigateToHome()
    {
        NavigationManager.NavigateTo("/");
    }

    private void ToggleProfileDropdown()
    {
        _profileDropdownOpen = !_profileDropdownOpen;
    }
}
