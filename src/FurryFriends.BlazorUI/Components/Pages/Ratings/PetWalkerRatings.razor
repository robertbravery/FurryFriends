@namespace FurryFriends.BlazorUI.Components.Pages.Ratings
@using FurryFriends.BlazorUI.Client.Services.Interfaces
@using FurryFriends.BlazorUI.Components.Common
@rendermode InteractiveServer

<div class="petwalker-ratings-container">
    <div class="ratings-header">
        <h4>@HeaderText</h4>
        @if (IsLoading)
        {
            <span class="loading-indicator">
                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                Loading...
            </span>
        }
    </div>

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="alert alert-danger" role="alert">
            @ErrorMessage
        </div>
    }

    @if (!IsLoading && Ratings != null && !Ratings.Any())
    {
        <div class="ratings-empty">
            <div class="empty-state-icon">&#9733;</div>
            <p class="empty-state-text">No ratings yet</p>
            <p class="empty-state-subtext">Be the first to leave a rating for this pet walker.</p>
        </div>
    }

    @if (Ratings != null && Ratings.Any())
    {
        <div class="ratings-list">
            @foreach (var rating in Ratings)
            {
                <div class="rating-item card mb-2">
                    <div class="card-body py-2">
                        <div class="rating-item-header">
                            <div class="rating-stars">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <span
                                    class="rating-star @(i <= rating.RatingValue ? "star-filled" : "star-empty")">&#9733;</span>
                                }
                            </div>
                            <div class="rating-meta">
                                @if (!string.IsNullOrEmpty(rating.ClientName))
                                {
                                    <span class="rating-author">@rating.ClientName</span>
                                }
                                <span class="rating-date">@rating.CreatedAt.ToString("MMM dd, yyyy")</span>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(rating.Comment))
                        {
                            <div class="rating-comment mt-1">
                                <p class="mb-0">@rating.Comment</p>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        <div class="ratings-footer">
            <div class="ratings-summary-text">
                Showing @((CurrentPage - 1) * PageSize + 1)-@Math.Min(CurrentPage * PageSize, TotalCount) of @TotalCount
                ratings
            </div>
            <div class="ratings-pagination">
                <button class="btn btn-sm @(HasPreviousPage ? "btn-outline-primary" : "btn-outline-secondary")"
                        @onclick="GoToPreviousPage" disabled="@(!HasPreviousPage)">
                    &laquo; Previous
                </button>
                <span class="pagination-page-info">Page @CurrentPage of @TotalPages</span>
                <button class="btn btn-sm @(HasNextPage ? "btn-outline-primary" : "btn-outline-secondary")"
                        @onclick="GoToNextPage" disabled="@(!HasNextPage)">
                    Next &raquo;
                </button>
            </div>
        </div>
    }
</div>
