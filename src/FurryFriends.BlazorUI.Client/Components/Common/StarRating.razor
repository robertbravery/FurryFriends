@if (ShowNumeric)
{
    <span>
        @for (int i = 1; i <= MaxRating; i++)
        {
            var starIndex = i;
            <span @onclick="() => OnStarClick(starIndex)" 
                  @onclick:preventDefault="IsInteractive"
                  style="cursor: @(IsInteractive ? "pointer" : "default"); font-size: @(Size)px; color: #ffc107;">
                @(i <= (int)Math.Round(Rating) ? "★" : "☆")
            </span>
        }
        @if (ShowNumericValue)
        {
            <span class="ms-2">(@Rating.ToString("F1"))</span>
        }
    </span>
}
else
{
    <span>
        @for (int i = 1; i <= MaxRating; i++)
        {
            <span style="font-size: @(Size)px; color: #ffc107;">
                @(i <= (int)Math.Round(Rating) ? "★" : "☆")
            </span>
        }
    </span>
}

@code {
    [Parameter]
    public double Rating { get; set; }

    [Parameter]
    public int MaxRating { get; set; } = 5;

    [Parameter]
    public bool ShowNumeric { get; set; }

    [Parameter]
    public bool ShowNumericValue { get; set; } = true;

    [Parameter]
    public bool IsInteractive { get; set; }

    [Parameter]
    public int Size { get; set; } = 24;

    [Parameter]
    public EventCallback<int> RatingChanged { get; set; }

    private async Task OnStarClick(int starIndex)
    {
        if (IsInteractive && RatingChanged.HasDelegate)
        {
            await RatingChanged.InvokeAsync(starIndex);
        }
    }
}
