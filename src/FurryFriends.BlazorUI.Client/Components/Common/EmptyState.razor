@using Microsoft.AspNetCore.Components

<div class="empty-state">
    <div class="empty-state-icon">
        <i class="@IconClass" aria-hidden="true"></i>
    </div>
    <h3>@Title</h3>
    <p>@Description</p>
    @if (!string.IsNullOrWhiteSpace(ActionText))
    {
        <button class="btn btn-primary" @onclick="HandleAction">
            <i class="fa-solid fa-plus" aria-hidden="true"></i> @ActionText
        </button>
    }
</div>

@code {
    [Parameter]
    public string IconClass { get; set; } = "fa-solid fa-inbox";

    [Parameter]
    public string Title { get; set; } = "No Items Found";

    [Parameter]
    public string Description { get; set; } = "There are no records to display.";

    [Parameter]
    public string? ActionText { get; set; }

    [Parameter]
    public EventCallback OnAction { get; set; }

    private async Task HandleAction()
    {
        await OnAction.InvokeAsync();
    }
}