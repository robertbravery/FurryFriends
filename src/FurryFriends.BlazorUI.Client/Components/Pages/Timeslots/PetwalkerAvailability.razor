@page "/petwalker/availability"
@using FurryFriends.BlazorUI.Client.Models.Timeslots

<PageTitle>Manage Availability - FurryFriends</PageTitle>

<div class="page-container">
    <div class="page-header">
        <h1>Manage Your Availability</h1>
        <p>Set your working hours and manage your available timeslots</p>
    </div>

    @if (isLoading)
    {
        <div class="loading-spinner">
            <div class="spinner"></div>
            <p>Loading...</p>
        </div>
    }
    else
    {
        <!-- Tab Navigation -->
        <div class="tabs">
            <button class="tab-btn @(activeTab == "hours" ? "active" : "")" @onclick="SetHoursTab">
                Working Hours
            </button>
            <button class="tab-btn @(activeTab == "slots" ? "active" : "")" @onclick="SetSlotsTab">
                Timeslots
            </button>
            <button class="tab-btn @(activeTab == "requests" ? "active" : "")" @onclick="SetRequestsTab">
                Custom Requests
            </button>
        </div>

        <!-- Working Hours Tab -->
        @if (activeTab == "hours")
        {
            <div class="tab-content">
                <div class="section-header">
                    <h2>Working Hours</h2>
                    <button class="btn-primary" @onclick="ShowAddWorkingHoursDialog">
                        Add Working Hours
                    </button>
                </div>

                @if (workingHoursList.Any())
                {
                    <div class="hours-grid">
                        @foreach (var dayGroup in workingHoursList.GroupBy(w => w.DayOfWeek).OrderBy(g => g.Key))
                        {
                            <div class="day-card">
                                <h3>@dayGroup.First().DayName</h3>
                                @foreach (var hours in dayGroup)
                                {
                                    <div class="hours-item">
                                        <span>@hours.StartTime.ToString("HH:mm") - @hours.EndTime.ToString("HH:mm")</span>
                                        <div class="hours-actions">
                                            <button class="btn-icon" @onclick="() => EditWorkingHours(hours)" title="Edit">
                                                ✏️
                                            </button>
                                            <button class="btn-icon btn-danger" @onclick="() => DeleteWorkingHours(hours.WorkingHoursId)" title="Delete">
                                                🗑️
                                            </button>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <p>No working hours set. Add your availability to start accepting bookings.</p>
                    </div>
                }
            </div>
        }

        <!-- Timeslots Tab -->
        @if (activeTab == "slots")
        {
            <div class="tab-content">
                <div class="section-header">
                    <h2>Available Timeslots</h2>
                    <button class="btn-primary" @onclick="ShowAddTimeslotDialog">
                        Add Timeslot
                    </button>
                </div>

                <div class="filters">
                    <div class="filter-group">
                        <label>Date Range:</label>
                        <input type="date" @bind="filterStartDate" />
                        <span>to</span>
                        <input type="date" @bind="filterEndDate" />
                        <button class="btn-secondary" @onclick="LoadTimeslots">Filter</button>
                    </div>
                </div>

                @if (timeslotsList.Any())
                {
                    <div class="timeslots-table">
                        <table>
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Start Time</th>
                                    <th>End Time</th>
                                    <th>Duration</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var slot in timeslotsList)
                                {
                                    <tr>
                                        <td>@slot.Date.ToString("yyyy-MM-dd")</td>
                                        <td>@slot.StartTime.ToString("HH:mm")</td>
                                        <td>@slot.EndTime.ToString("HH:mm")</td>
                                        <td>@slot.DurationInMinutes min</td>
                                        <td>
                                            <span class="status-badge @slot.Status.ToLower()">@slot.Status</span>
                                        </td>
                                        <td>
                                            <button class="btn-icon btn-danger" @onclick="() => DeleteTimeslot(slot.TimeslotId)" title="Delete">
                                                🗑️
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <p>No timeslots available. Add timeslots within your working hours.</p>
                    </div>
                }
            </div>
        }

        <!-- Custom Requests Tab -->
        @if (activeTab == "requests")
        {
            <div class="tab-content">
                <div class="section-header">
                    <h2>Custom Time Requests</h2>
                    <div class="filter-group">
                        <select @onchange="OnStatusFilterChanged">
                            <option value="">All Requests</option>
                            <option value="Pending">Pending</option>
                            <option value="Accepted">Accepted</option>
                            <option value="Declined">Declined</option>
                            <option value="CounterOffered">Counter-Offered</option>
                        </select>
                    </div>
                </div>

                @if (customRequestsList.Any())
                {
                    <div class="requests-list">
                        @foreach (var request in customRequestsList)
                        {
                            <div class="request-card">
                                <div class="request-header">
                                    <h3>Request from @request.ClientName</h3>
                                    <span class="status-badge @request.Status.ToLower()">@request.Status</span>
                                </div>
                                <div class="request-details">
                                    <p><strong>Date:</strong> @request.RequestedDate.ToString("yyyy-MM-dd")</p>
                                    <p><strong>Preferred Time:</strong> @request.PreferredStartTime.ToString("HH:mm") - @request.PreferredEndTime.ToString("HH:mm")</p>
                                    <p><strong>Duration:</strong> @request.PreferredDurationMinutes minutes</p>
                                    <p><strong>Address:</strong> @request.ClientAddress</p>
                                    @if (request.PetNames.Any())
                                    {
                                        <p><strong>Pets:</strong> @string.Join(", ", request.PetNames)</p>
                                    }
                                    <p><strong>Requested:</strong> @request.CreatedAt.ToString("g")</p>
                                </div>
                                @if (request.Status == "Pending")
                                {
                                    <div class="request-actions">
                                        <button class="btn-success" @onclick="() => AcceptRequest(request.RequestId)">
                                            Accept
                                        </button>
                                        <button class="btn-danger" @onclick="() => DeclineRequest(request.RequestId)">
                                            Decline
                                        </button>
                                        <button class="btn-secondary" @onclick="() => ShowCounterOfferDialog(request)">
                                            Counter Offer
                                        </button>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <p>No custom time requests.</p>
                    </div>
                }
            </div>
        }
    }

    <!-- Add Working Hours Modal -->
    @if (showWorkingHoursDialog)
    {
        <div class="modal-overlay" @onclick="CloseWorkingHoursDialog">
            <div class="modal-content" @onclick:stopPropagation="true">
                <h3>@(editingWorkingHours != null ? "Edit Working Hours" : "Add Working Hours")</h3>
                
                <div class="form-group">
                    <label>Day of Week</label>
                    <select @bind="workingHoursForm.DayOfWeek" disabled="@(editingWorkingHours != null)">
                        @foreach (DayOfWeek day in Enum.GetValues<DayOfWeek>())
                        {
                            <option value="@day">@day</option>
                        }
                    </select>
                </div>
                
                <div class="form-group">
                    <label>Start Time</label>
                    <input type="time" @bind="workingHoursForm.StartTime" />
                </div>
                
                <div class="form-group">
                    <label>End Time</label>
                    <input type="time" @bind="workingHoursForm.EndTime" />
                </div>

                @if (editingWorkingHours != null)
                {
                    <div class="form-group">
                        <label>
                            <input type="checkbox" @bind="workingHoursForm.IsActive" />
                            Active
                        </label>
                    </div>
                }

                <div class="modal-actions">
                    <button class="btn-secondary" @onclick="CloseWorkingHoursDialog">Cancel</button>
                    <button class="btn-primary" @onclick="SaveWorkingHours">
                        @(editingWorkingHours != null ? "Update" : "Add")
                    </button>
                </div>
            </div>
        </div>
    }

    <!-- Add Timeslot Modal -->
    @if (showTimeslotDialog)
    {
        <div class="modal-overlay" @onclick="CloseTimeslotDialog">
            <div class="modal-content" @onclick:stopPropagation="true">
                <h3>Add Timeslot</h3>
                
                <div class="form-group">
                    <label>Date</label>
                    <input type="date" @bind="timeslotForm.Date" />
                </div>
                
                <div class="form-group">
                    <label>Start Time</label>
                    <input type="time" @bind="timeslotForm.StartTime" />
                </div>
                
                <div class="form-group">
                    <label>Duration (minutes)</label>
                    <select @bind="timeslotForm.DurationInMinutes">
                        <option value="30">30 minutes</option>
                        <option value="45">45 minutes</option>
                    </select>
                </div>

                <div class="modal-actions">
                    <button class="btn-secondary" @onclick="CloseTimeslotDialog">Cancel</button>
                    <button class="btn-primary" @onclick="SaveTimeslot">Add Timeslot</button>
                </div>
            </div>
        </div>
    }

    <!-- Counter Offer Modal -->
    @if (showCounterOfferDialog && selectedRequest != null)
    {
        <div class="modal-overlay" @onclick="CloseCounterOfferDialog">
            <div class="modal-content" @onclick:stopPropagation="true">
                <h3>Counter Offer</h3>
                <p>Suggest an alternative time for the client:</p>
                
                <div class="form-group">
                    <label>Date</label>
                    <input type="date" @bind="counterOfferForm.Date" />
                </div>
                
                <div class="form-group">
                    <label>Start Time</label>
                    <input type="time" @bind="counterOfferForm.StartTime" />
                </div>
                
                <div class="form-group">
                    <label>Duration (minutes)</label>
                    <select @bind="counterOfferForm.DurationMinutes">
                        <option value="30">30 minutes</option>
                        <option value="45">45 minutes</option>
                    </select>
                </div>

                <div class="modal-actions">
                    <button class="btn-secondary" @onclick="CloseCounterOfferDialog">Cancel</button>
                    <button class="btn-primary" @onclick="SubmitCounterOffer">Send Counter Offer</button>
                </div>
            </div>
        </div>
    }

    <!-- Error/Success Messages -->
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-error">
            <span>@errorMessage</span>
            <button @onclick="() => errorMessage = null">✕</button>
        </div>
    }

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success">
            <span>@successMessage</span>
            <button @onclick="() => successMessage = null">✕</button>
        </div>
    }
</div>

<style>
    .page-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 20px;
    }

    .page-header {
        margin-bottom: 24px;
    }

    .page-header h1 {
        font-size: 28px;
        margin-bottom: 8px;
    }

    .tabs {
        display: flex;
        gap: 4px;
        margin-bottom: 24px;
        border-bottom: 2px solid #e0e0e0;
    }

    .tab-btn {
        padding: 12px 24px;
        border: none;
        background: none;
        cursor: pointer;
        font-size: 16px;
        color: #666;
        border-bottom: 3px solid transparent;
        margin-bottom: -2px;
    }

    .tab-btn.active {
        color: #007bff;
        border-bottom-color: #007bff;
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .hours-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        gap: 16px;
    }

    .day-card {
        background: #fff;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        padding: 16px;
    }

    .day-card h3 {
        margin: 0 0 12px 0;
        color: #333;
    }

    .hours-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 8px 0;
        border-bottom: 1px solid #f0f0f0;
    }

    .hours-actions {
        display: flex;
        gap: 8px;
    }

    .btn-icon {
        background: none;
        border: none;
        cursor: pointer;
        font-size: 16px;
        padding: 4px;
    }

    .btn-danger {
        color: #dc3545;
    }

    .timeslots-table {
        overflow-x: auto;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th, td {
        padding: 12px;
        text-align: left;
        border-bottom: 1px solid #e0e0e0;
    }

    th {
        background: #f8f9fa;
        font-weight: 600;
    }

    .status-badge {
        display: inline-block;
        padding: 4px 8px;
        border-radius: 4px;
        font-size: 12px;
        font-weight: 500;
    }

    .status-badge.available {
        background: #d4edda;
        color: #155724;
    }

    .status-badge.booked {
        background: #cce5ff;
        color: #004085;
    }

    .status-badge.pending {
        background: #fff3cd;
        color: #856404;
    }

    .status-badge.accepted {
        background: #d4edda;
        color: #155724;
    }

    .status-badge.declined {
        background: #f8d7da;
        color: #721c24;
    }

    .status-badge.counteroffered {
        background: #e2e3e5;
        color: #383d41;
    }

    .requests-list {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .request-card {
        background: #fff;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        padding: 20px;
    }

    .request-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 16px;
    }

    .request-header h3 {
        margin: 0;
    }

    .request-details p {
        margin: 8px 0;
    }

    .request-actions {
        display: flex;
        gap: 12px;
        margin-top: 16px;
    }

    .filters {
        margin-bottom: 20px;
    }

    .filter-group {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .empty-state {
        text-align: center;
        padding: 40px;
        color: #666;
    }

    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0,0,0,0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }

    .modal-content {
        background: white;
        padding: 24px;
        border-radius: 8px;
        width: 90%;
        max-width: 500px;
    }

    .modal-content h3 {
        margin-top: 0;
    }

    .form-group {
        margin-bottom: 16px;
    }

    .form-group label {
        display: block;
        margin-bottom: 4px;
        font-weight: 500;
    }

    .form-group input,
    .form-group select {
        width: 100%;
        padding: 8px;
        border: 1px solid #ccc;
        border-radius: 4px;
    }

    .modal-actions {
        display: flex;
        gap: 12px;
        justify-content: flex-end;
        margin-top: 20px;
    }

    .btn-primary,
    .btn-secondary,
    .btn-success,
    .btn-danger {
        padding: 8px 16px;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        font-size: 14px;
    }

    .btn-primary {
        background: #007bff;
        color: white;
    }

    .btn-secondary {
        background: #6c757d;
        color: white;
    }

    .btn-success {
        background: #28a745;
        color: white;
    }

    .btn-danger {
        background: #dc3545;
        color: white;
    }

    .alert {
        padding: 12px 16px;
        border-radius: 4px;
        margin-bottom: 16px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .alert-error {
        background: #f8d7da;
        color: #721c24;
    }

    .alert-success {
        background: #d4edda;
        color: #155724;
    }

    .loading-spinner {
        text-align: center;
        padding: 40px;
    }

    .spinner {
        border: 4px solid #f3f3f3;
        border-top: 4px solid #007bff;
        border-radius: 50%;
        width: 40px;
        height: 40px;
        animation: spin 1s linear infinite;
        margin: 0 auto;
    }

    @@keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }
</style>
